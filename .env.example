# Required
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional — DeepEval's Confident AI platform (for dashboard/tracking)
# CONFIDENT_API_KEY=your-confident-api-key

# Optional — LangSmith tracing for RAGAS debugging
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key

# Optional — Override default evaluation history database path
# RAGEVALS_HISTORY_DB=/path/to/custom/history.db
